        <value-of select="$expected-attributes[name() eq 'notBefore']"/>
    </sqf:add>
    <sqf:add node-type="attribute" target="notAfter"
        use-when="$expected-attributes[name() eq 'notAfter']">
        <value-of select="$expected-attributes[name() eq 'notAfter']"/>
    </sqf:add>
</sqf:fix>

</rule>
</pattern>

